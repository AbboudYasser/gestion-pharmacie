# ملف مثال لمتغيرات البيئة
# انسخ هذا الملف إلى .env وقم بتعديل القيم حسب بيئتك

# ===== إعدادات الواجهة الخلفية (Backend) =====

# إعدادات Flask
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# إعدادات قاعدة البيانات Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project.iam.gserviceaccount.com

# إعدادات JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600

# إعدادات CORS
CORS_ORIGINS=http://localhost:3000,https://yourusername.github.io

# ===== إعدادات الواجهة الأمامية (Frontend) =====

# عنوان API للواجهة الخلفية
REACT_APP_API_BASE_URL=http://localhost:5000/api

# إعدادات البيئة
REACT_APP_ENVIRONMENT=development
REACT_APP_DEBUG=true
REACT_APP_ENABLE_MOCK_DATA=false

# إعدادات Supabase (للمستقبل)
REACT_APP_SUPABASE_URL=your-supabase-url
REACT_APP_SUPABASE_ANON_KEY=your-supabase-anon-key

# ===== إعدادات النشر =====

# GitHub Pages
GITHUB_PAGES_URL=https://yourusername.github.io/repository-name

# Heroku (للواجهة الخلفية)
HEROKU_APP_NAME=your-heroku-app-name

# Railway (بديل لـ Heroku)
RAILWAY_PROJECT_ID=your-railway-project-id

# ===== إعدادات أخرى =====

# إعدادات البريد الإلكتروني (للإشعارات)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# إعدادات التخزين السحابي
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BUCKET_NAME=your-s3-bucket-name

# إعدادات المراقبة والتحليلات
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
SENTRY_DSN=your-sentry-dsn

# ===== ملاحظات مهمة =====

# 1. لا تشارك هذا الملف مع أي شخص بعد ملء القيم الحقيقية
# 2. تأكد من إضافة .env إلى ملف .gitignore
# 3. استخدم كلمات مرور قوية ومفاتيح تشفير آمنة
# 4. قم بتغيير جميع المفاتيح السرية في بيئة الإنتاج
# 5. استخدم GitHub Secrets لحفظ المتغيرات الحساسة في CI/CD
